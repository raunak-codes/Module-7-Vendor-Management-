DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/vendor_management"
JWT_SECRET="eventhub360-vendor-management-secret-key"
PORT=5000
NODE_ENV=development
LOG_LEVEL=http
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:5174

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=vendor-docs

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

